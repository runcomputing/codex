+        .as_std()
+        .get_envs()
+        .map(|(key, value)| (key.to_os_string(), value.map(OsStr::to_os_string)))
+        .collect::<BTreeMap<OsString, Option<OsString>>>();
+
+    assert_eq!(envs.get(&OsString::from("CODEX_THREAD_ID")), Some(&None));
+}
