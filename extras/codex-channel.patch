+    env: Option<HashMap<String, String>>,
+    runtime_context: &McpRuntimeContext,
+) -> Option<HashMap<OsString, OsString>> {
+    let mut env_os = env
+        .map(|env| {
+            env.into_iter()
+                .map(|(key, value)| (key.into(), value.into()))
+                .collect::<HashMap<_, _>>()
